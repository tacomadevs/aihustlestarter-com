---
// Fonts loaded via Google Fonts in Layout.astro
---

<style is:inline>
  :root {
    --aw-font-sans: 'Plus Jakarta Sans';
    --aw-font-serif: 'Plus Jakarta Sans';
    --aw-font-heading: 'Space Grotesk';

    --aw-color-primary: rgb(90 47 160);
    --aw-color-secondary: rgb(45 15 94);
    --aw-color-accent: rgb(245 166 35);

    --aw-color-text-heading: rgb(26 10 46);
    --aw-color-text-default: rgb(26 10 46);
    --aw-color-text-muted: rgb(26 10 46 / 60%);
    --aw-color-bg-page: rgb(250 247 242);

    --aw-color-bg-page-dark: rgb(250 247 242);

    ::selection {
      background-color: rgb(245 166 35 / 30%);
    }
  }
</style>
