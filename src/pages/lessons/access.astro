---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Signing you in...' };
---

<Layout metadata={metadata}>
  <section style="min-height: 80vh; display: flex; align-items: center; justify-content: center; background: #0f0a1e;">
    <div class="text-center px-4">
      <div
        class="mx-auto mb-6"
        style="width: 48px; height: 48px; border: 4px solid #f5a623; border-top-color: transparent; border-radius: 50%; animation: spin 0.8s linear infinite;"
      ></div>
      <p class="text-white text-lg" id="status-msg">Signing you in...</p>
    </div>
  </section>
</Layout>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script is:inline>
  async function handleSignIn() {
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');
    const statusEl = document.getElementById('status-msg');

    if (!token) {
      window.location.href = '/sign-in';
      return;
    }

    try {
      await window.Clerk.load();

      const signIn = await window.Clerk.client.signIn.create({
        strategy: 'ticket',
        ticket: token,
      });

      if (signIn.status === 'complete') {
        await window.Clerk.setActive({ session: signIn.createdSessionId });
        window.location.href = '/lessons';
      } else {
        statusEl.textContent = 'Something went wrong. Redirecting to sign in...';
        setTimeout(() => (window.location.href = '/sign-in'), 2000);
      }
    } catch {
      statusEl.textContent = 'Link expired or already used. Redirecting to sign in...';
      setTimeout(() => (window.location.href = '/sign-in'), 2000);
    }
  }
</script>

<script
  is:inline
  data-clerk-publishable-key="pk_live_Y2xlcmsuYWlodXN0bGVzdGFydGVyLmNvbSQ"
  src="https://clerk.aihustlestarter.com/npm/@clerk/clerk-js@6.14.0/dist/clerk.browser.js"
  crossorigin="anonymous"
  onload="handleSignIn()"
></script>
