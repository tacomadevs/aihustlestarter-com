---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Sign In — AI HustleStarter' };
---

<Layout metadata={metadata}>
  <section style="min-height: 80vh; display: flex; align-items: center; justify-content: center; background: #0f0a1e;">
    <div id="sign-in-mount"></div>
  </section>
</Layout>

<script is:inline>
  async function initSignIn() {
    try {
      await window.Clerk.load({
        signInUrl: '/sign-in',
        signUpUrl: '/sign-in',
        appearance: {},
      });

      if (window.Clerk.user) {
        window.location.href = '/lessons';
        return;
      }

      window.Clerk.mountSignIn(document.getElementById('sign-in-mount'), {
        routing: 'virtual',
        fallbackRedirectUrl: '/lessons',
        signUpFallbackRedirectUrl: '/lessons',
      });
    } catch (err) {
      document.getElementById('sign-in-mount').innerHTML =
        '<p style="color:#f5a623;font-family:sans-serif;padding:20px">Auth error: ' + err.message + '</p>';
      console.error('Clerk init error:', err);
    }
  }
</script>

<script
  is:inline
  data-clerk-publishable-key="pk_live_Y2xlcmsuYWlodXN0bGVzdGFydGVyLmNvbSQ"
  src="https://clerk.aihustlestarter.com/npm/@clerk/clerk-js@6.14.0/dist/clerk.browser.js"
  crossorigin="anonymous"
  onload="initSignIn()"
></script>
