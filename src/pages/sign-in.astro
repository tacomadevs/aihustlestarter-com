---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Sign In — AI HustleStarter' };
---

<Layout metadata={metadata}>
  <section style="min-height: 80vh; display: flex; align-items: center; justify-content: center; background: #0f0a1e;">
    <div id="sign-in-mount"></div>
  </section>
</Layout>

<script is:inline>
  async function initSignIn() {
    await window.Clerk.load();

    if (window.Clerk.user) {
      window.location.href = '/lessons';
      return;
    }

    window.Clerk.mountSignIn(document.getElementById('sign-in-mount'), {
      afterSignInUrl: '/lessons',
      afterSignUpUrl: '/lessons',
    });
  }
</script>

<script
  is:inline
  data-clerk-publishable-key="pk_test_Y2xlYW4tcGFyYWtlZXQtMzkuY2xlcmsuYWNjb3VudHMuZGV2JA"
  src="https://clean-parakeet-39.clerk.accounts.dev/npm/@clerk/clerk-js@6.14.0/dist/clerk.browser.js"
  crossorigin="anonymous"
  onload="initSignIn()"
></script>
