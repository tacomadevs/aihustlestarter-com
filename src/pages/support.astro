---
import Layout from '~/layouts/PageLayout.astro';

const metadata = { title: 'Support' };
---

<Layout metadata={metadata}>

  <section class="py-16" style="background: #faf7f2;">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-widest mb-2" style="color: #5a2fa0;">Need help?</p>
      <h1 class="text-4xl md:text-5xl font-black mb-4" style="font-family: 'Space Grotesk', sans-serif; color: #2d0f5e;">
        Support
      </h1>
      <p class="text-lg mb-12" style="color: rgb(26 10 46 / 70%);">
        Most issues resolve in under 2 minutes. Check the common fixes below before reaching out.
      </p>

      <!-- Lesson access help -->
      <div class="mb-12">
        <h2 class="text-2xl font-black mb-4" style="font-family: 'Space Grotesk', sans-serif; color: #2d0f5e;">
          Can't access your lessons?
        </h2>
        <ol class="space-y-3">
          {[
            'Check the email you used to purchase. Look for a message from aihustlestarter.com or GoHighLevel.',
            'Search your inbox for "AI Hustle" or "your lessons" — it may have landed in Promotions or Spam.',
            'Click the lesson access link in that email. It takes you directly to your lesson hub.',
            'If you bought on TikTok Shop, allow 24 hours for the welcome email to arrive after your order is confirmed.',
            'Still nothing? Use the contact form below and include your order confirmation number.',
          ].map((step, i) => (
            <li class="flex items-start gap-4">
              <span class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center font-black text-white text-sm mt-0.5" style="background: #5a2fa0;">
                {i + 1}
              </span>
              <p style="color: #1a0a2e;">{step}</p>
            </li>
          ))}
        </ol>
      </div>

      <!-- Workbook shipping -->
      <div class="mb-12 p-6 rounded-2xl" style="background: #ede0f9;">
        <h2 class="text-2xl font-black mb-3" style="font-family: 'Space Grotesk', sans-serif; color: #2d0f5e;">
          Workbook shipping questions
        </h2>
        <p class="mb-3" style="color: #1a0a2e;">
          The physical workbook ships within 1–3 business days of your order. For shipping status, check your TikTok Shop order page — tracking updates appear there once your order ships.
        </p>
        <p style="color: rgb(26 10 46 / 70%);">
          If your order shows as delivered but you haven't received it, wait 2 business days (carrier delays happen) then contact us below.
        </p>
      </div>

      <!-- Contact form -->
      <div>
        <h2 class="text-2xl font-black mb-4" style="font-family: 'Space Grotesk', sans-serif; color: #2d0f5e;">
          Contact us
        </h2>
        <p class="mb-6" style="color: rgb(26 10 46 / 70%);">
          We typically respond within 24 hours on business days. Include your order number when possible — it speeds things up.
        </p>
        <!-- GHL support form embed — see ghl-build-brief.md item 11 -->
        <div class="rounded-2xl p-8 text-center" style="background: #fef3d8; border: 1px dashed #f5a623;">
          <p class="font-medium mb-1" style="color: #5a2fa0;">Contact form coming soon</p>
          <p class="text-sm" style="color: rgb(26 10 46 / 60%);">GHL support form embed goes here</p>
        </div>
      </div>

    </div>
  </section>

</Layout>
